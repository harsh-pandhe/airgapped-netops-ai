# ── Air-Gapped NetOps AI — environment template ──
# Copy to .env and adjust. Never commit .env.

# ── LLM (local Ollama) ──
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:3b

# ── Telemetry source ──
TELEMETRY_MODE=mock          # mock | snmp
TELEMETRY_INTERVAL_S=2
SNMP_COMMUNITY=public
SNMP_TARGETS=                # comma-separated IPs when TELEMETRY_MODE=snmp

# ── Auth / security ──
# Set a strong secret in production. Do NOT ship the default.
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=8

# Demo accounts: off unless DEMO_MODE=true OR the two passwords below are set.
DEMO_MODE=false
# DEFAULT_OPERATOR_PASSWORD=
# DEFAULT_ARCHITECT_PASSWORD=

# ── Offline model enforcement (recommended for true air-gap) ──
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
